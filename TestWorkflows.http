POST {{host}}/api/workflows/RemoteProcessing
Content-Type: application/json

{
  "orderId": "ord-3",
  "customerId": "cust-1",
  "customerEmail": "test@example.com",
  "correlationId": "corr-v2-001",
  "lineItems": [
    { "lineItemId": "li-1", "productId": "prod-1", "quantity": 2 }
